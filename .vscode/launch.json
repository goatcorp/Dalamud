{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Wine netcoredbg Dalamud.Injector with lldb-server",
            "type": "coreclr",
            "request": "launch",
            "cwd": "${workspaceFolder}/bin/Debug",
            "program": "${workspaceFolder}/bin/Debug/Dalamud.Injector.exe",
            "args": [
                "launch",
                "-f",
                "--wrap=../../linuxtools/lldb/lldb-server.exe",
                "--wraparg=g",
                "--wraparg=localhost:12345",
            ],
            "stopAtEntry": false,
            "console": "internalConsole",
            "pipeTransport": {
                "pipeCwd": "${workspaceFolder}",
                "pipeProgram": "/bin/bash",
                "pipeArgs": [
                    "-c",
                    "export DOTNET_ROOT=$(xlcore wine winepath -w ~/.xlcore/runtime/); export DALAMUD_RUNTIME=$DOTNET_ROOT; exec xlcore wine $(xlcore wine winepath -w linuxtools/netcoredbg/netcoredbg.exe) --interpreter=vscode"
                ],
                "debuggerPath": "#"
            }
        },
        {
            "name": "Attach to Dalamud.Boot via lldb-server on localhost:12345",
            "type": "lldb-dap",
            "request": "attach",
            "program": "${workspaceFolder}/bin/Debug/Dalamud.Boot.dll",
            "stopOnEntry": true,
            "attachCommands": ["gdb-remote localhost:12345"],
        },
        {
            "name": "Launch Wine netcoredbg Dalamud.Injector with gdbserver",
            "type": "coreclr",
            "request": "launch",
            "cwd": "${workspaceFolder}/bin/Debug",
            "program": "${workspaceFolder}/bin/Debug/Dalamud.Injector.exe",
            "args": [
                "launch",
                "-f",
                "--wrap=../../linuxtools/gdb/gdbserver.exe",
                "--wraparg=--once",
                "--wraparg=localhost:12345",
            ],
            "stopAtEntry": false,
            "console": "internalConsole",
            "pipeTransport": {
                "pipeCwd": "${workspaceFolder}",
                "pipeProgram": "/bin/bash",
                "pipeArgs": [
                    "-c",
                    "export DOTNET_ROOT=$(xlcore wine winepath -w ~/.xlcore/runtime/); export DALAMUD_RUNTIME=$DOTNET_ROOT; exec xlcore wine $(xlcore wine winepath -w linuxtools/netcoredbg/netcoredbg.exe) --interpreter=vscode"
                ],
                "debuggerPath": "#"
            }
        },
        {
            "name": "Attach to Dalamud.Boot via gdbserver on localhost:12345",
            "type": "cppdbg",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/bin/Debug/Dalamud.Boot.dll",
            "stopAtEntry": true,
            "miDebuggerServerAddress": "localhost:12345",
            "externalConsole": true,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Launch build/build.csproj",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "Build build/build.csproj",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/build/bin/Debug/build.dll",
            "args": [],
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "type": "cmake",
            "request": "launch",
            "name": "CMake configure DalamudCrashHandler",
            "cmakeDebugType": "configure",
            "clean": false,
            "configureAll": false
        },
        {
            "name": "Launch Wine gdbserver Debug DalamudCrashHandler and attach gdb",
            "type": "cppdbg",
            "request": "launch",
            "cwd": "${workspaceRoot}",
            "program": "${workspaceFolder}/bin/Debug/DalamudCrashHandler.exe",
            "stopAtEntry": true,
            // pipeTransport only works to some degree, e.g. -exec c works but the continue button doesn't.
            "miDebuggerServerAddress": "localhost:12345",
            "externalConsole": true,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Wine gdbserver Debug DalamudCrashHandler"
        }
    ]
}